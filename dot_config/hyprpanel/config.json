  "theme.bar.layer": "overlay",
  "theme.bar.margin_top": "0em",
  "theme.bar.margin_sides": "0em",
  "theme.bar.margin_bottom": "-4px",
  "notifications.showActionsOnHover": true,
  "menus.transition": "crossfade",
  "notifications.ignore": [
    "archdots"
