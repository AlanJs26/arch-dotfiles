#######################################################################
#                     Advanced Layout Management                      #
#######################################################################

# Flip all nodes in current desktop
super + {comma,period}
	bspc node @/ -F {horizontal,vertical}

# Rotate tree positions
super + {_,shift + } ccedilla
    bspc node @/ -C {forward,backward}

# Rotate tree layout
super + alt + {_,shift + } ccedilla
    bspc node @/ -R {90,270}

# Expand a window by moving one of its side outward
super + alt + {h,j,k,l}
  bspwm-resize.sh {x -, y +, y -, x +}

# Rotate tree layout (relative)
super + {_,shift + } bracketleft
	bspc node @parent -R {90,270}

# Toggle automatic balancing of windows (relative)
super + bracketright
	node_state="$(bspc query -T -n focused|jq '.client.state' -r)";\
	if [ "$node_state" = "floating" ]; then;\
		center_floating_window.sh;\
	else;\
		bspc query -N -d | xargs -I % bspc node % -E;\
	fi
