#######################################################################
#                            Manage Bspwm                             #
#######################################################################


# Quit/restart bspwm
super + alt + r
	bspc wm -r

# Restart scripts
super + shift + r
	dots autostart --restart scripts && notify-send -a bspwm 'Bspwm' 'Restarted all scripts' -u low;

# Restart programs
super + shift + alt + r
	dots autostart --restart programs && notify-send -a bspwm 'Bspwm' 'Restarted all autostart programs' -u low;

# Close and kill
super + {shift + ,alt + }q
	[ "$(bspc query -T -n focused|jq .client.className -r)" = "tabbed" ]\
	&& (id="$(bsptab list|head -n1)"; bsptab remove $id && sleep 0.1 && bspc node $id -{c,k})\
	|| bspc node -{c,k}


# Increase/Decrease Gaps
super + {equal, minus} 
    { bspc config -d focused window_gap $(( $(bspc config -d focused window_gap) + 10 )), \
    [ $(bspc config -d focused window_gap) -ge 10 ] && \
			bspc config -d focused window_gap $(( $(bspc config -d focused window_gap) - 10 )) }



#######################################################################
#                            Window State                             #
#######################################################################

# Add or remove window from tabbed wrapper
super + {_,shift + }w
	bsptab {add,remove}

# Alternate between the tiled and monocle layout
super + a
	bspc desktop -l next;\
	polybar-msg action bspwm-monocle hook 0

# Toggle Floating/Tiled
super + s
	state="$(bspc query -T -n |jq ".client.state" -r)";\
	[ "$state" = "floating" ] && bspc node -t tiled || bspc node -t floating
	# bspc node -t "~floating"

# Toggle Pseudo Tiled/Tiled
super + t
	state="$(bspc query -T -n |jq ".client.state" -r)";\
	[ "$state" = "pseudo_tiled" ] && bspc node -t tiled || bspc node -t pseudo_tiled

# Toggle fullscreen
super + f 
  bspc node -t "~fullscreen"	

# Set Window as locked/sticky/private
super + ctrl + {o,s,p}
	bspc node -g {locked,sticky,private}

# Mark node or move marked node to preselection
super + ctrl + a
	if [ -n "$(bspc query -N -n .marked.\!floating.\!focused.window)" ];then;\
		bspc node newest.marked -n newest.\!automatic;\
		bspc query -N -n .\!floating|xargs -i bspc node \{\} -g marked=off;\
	else;\
		bspc node -g marked;\
	fi


#######################################################################
#                            Focus Windows                            #
#######################################################################

# Focus Window
super + {h,j,k,l}
	focusmover.sh {west,south,north,east}

# Focus Window (Arrow Keys)
super + {Left,Down,Up,Right}
	focusmover.sh {west,south,north,east}

# Go go next monitor
super + u
	bspc config pointer_follows_monitor true;\
  bspc monitor -f last;\
	bspc config pointer_follows_monitor false

# Focus the next/previous window in the current desktop
super + {_,shift + }x
	if [ "$(bspc query -T -d focused|jq .userLayout -r)" = "monocle" ]; then;\
		bspc node -f {next,prev}.local.\!hidden.\!floating.window;\
	else;\
		bspc node -f {next,prev}.local.\!hidden.window;\
	fi

# Switch window on alt release
alt + {shift + ,_}~Tab
	if ! bspc query -T -n focused|jq .client.className -r|rg 'tabbed'; then;\
		if [ "$(bspc query -T -d focused|jq .userLayout -r)" = "monocle" ]; then;\
			bspc node -f {next,prev}.local.\!hidden.\!floating.window;\
		else;\
			bspwm-alttab.sh;\
		fi;\
	fi

	# rofi -kb-accept-entry '!Alt-Tab' -kb-row-down Alt-Tab -show windowcd

# Focus the next/previous desktop in the current monitor
super + {shift + ,_}Tab
	DIR="{prev,next}";\
	if ! [ $(bspc query -N -n .\!hidden.local.leaf) ]; then;\
		bspc query -N -n .hidden.local.leaf|xargs -i bspc node \{\} -d $DIR.local.occupied;\
	fi;\
	bspc desktop -f $DIR.local.occupied

# Focus the older or newer node in the focus history
super + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on


#######################################################################
#                            Move Windows                             #
#######################################################################

# Swap the current node and the biggest window
super + d
	bspc node -s biggest.window.local || \
	bspc node -s last.local

# Transplant into window in chosen direction
super + shift + ctrl + {Left,Down,Up,Right}
  bspwm-bubble-move.sh {west,south,north,east}

# Transplant into window in chosen direction (allow rotation)
super + shift + {Left,Down,Up,Right}
  bspwm-bubble-move.sh -r {west,south,north,east}

# Move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}

# Swap Windows
super + shift + {h,j,k,l}
	dir="{west,south,north,east}";\
	node_state="$(bspc query -T -n focused|jq '.client.state' -r)";\
	if [ "$node_state" = "floating" ] || [ -z "$(bspc query -N -n "$dir.local.!floating")" ]; then;\
		bspc node -m $dir --follow;\
	else;\
		bspc node -s "$dir.local.!floating";\
	fi
	# windowgrabber {west,south,north,east}

# Swap desktop with next/prev monitor
super + shift + ctrl + {h,l}
	swap-desktops.sh {prev,next}
  # bspc desktop --to-monitor {prev,next} --follow

# Send a window to the next occupied workspace and focus it
super + {_,shift + } alt + Tab
	bspc node -d {next,prev}.local.occupied -f

# Focus next free desktop or send a window there
super + {_,shift + }apostrophe
	bspc {desktop -f, node -d} any.local.\!occupied

# Send a window to the next free workspace and focus it
super + alt + apostrophe
	bspc node -d any.local.\!occupied -f

# Focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '{1-9,10}'
	# bspc {desktop -f,node -d} '^{1-9,10}'

# Send and focus to the given desktop
super + alt + {1-9,0}
	bspc node -d '{1-9,10}' -f


