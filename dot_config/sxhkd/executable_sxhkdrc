#                            Focus Windows                            #
#######################################################################

# Focus next tabbed window
# Alt + Tab
# 	tabc 

# Focus Window
super + {h,j,k,l}
	focusmover.sh {west,south,north,east}

# Focus Window (Arrow Keys)
super + {Left,Down,Up,Right}
	focusmover.sh {west,south,north,east}

# Go go next monitor
super + u
  bspc monitor -f last

# Focus the next/previous window in the current desktop
super + {_,shift + }x
	if [ "$(bspc query -T -d focused|jq .userLayout -r)" = "monocle" ]; then;\
		bspc node -f {next,prev}.local.\!hidden.\!floating.window;\
	else;\
		bspc node -f {next,prev}.local.\!hidden.window;\
	fi

