#######################################################################
#                             Scratchpad                              #
#######################################################################

# Hide window
super + ctrl + m
	bspc node --flag hidden=on

# Toggle all floating windows
super + alt + {s,o}
	scratchpad.py --behaviour toggleall

# Add window to scratchpad
super + alt + a
	bspc node --flag hidden=on -t floating

# Cicle all scratchpad windows
super + shift + a
	scratchpad.py ".*" --behaviour i3 --not_class "$(bash bsplaunch pdf_viewer -r)|qalculate-gtk" --not_title "(YouTube Music)|mpv|Spotify|floatkitty"

# Youtube Music or MPV
super + ctrl + z
	scratchpad.py "(YouTube Music)|mpv|Spotify" --behaviour nomark

# Audio Relay
super + shift + s
	scratchpad.py --class "com-azefsw-audioconnect-desktop-app-MainKt" --behaviour nomark

# Pdf Viewer
super + shift + backslash
	scratchpad.py --class "$(bash bsplaunch pdf_viewer -r)" --behaviour swap

# Qalculate
super + ctrl + backslash
	scratchpad.py --class "qalculate-gtk" -r "qalculate-gtk" --behaviour nomark

# Floating terminal kitty
super + shift + z
	scratchpad.py "floatkitty" --class "__float__|__float_center__" -r "kitty --title floatkitty --class __float_center__" --behaviour nomark

# Floating kitty neovim
super + alt + Return
	scratchpad.py "floatkittynvim$" --class "__float__|__float_center__" -r "kitty --title floatkittynvim --class __float_center__ nvim" --behaviour i3


#######################################################################
#                            Manage Bspwm                             #
#######################################################################


# Quit/restart bspwm
super + alt + r
	bspc wm -r

# Restart scripts
super + shift + r
	bash $BSPDIR/bspscripts restart scripts && notify-send -a bspwm 'Bspwm' 'Restarted all scripts' -u low;

# Restart programs
super + shift + alt + r
	bash $BSPDIR/bspscripts restart programs && notify-send -a bspwm 'Bspwm' 'Restarted all autostart programs' -u low;

# Close and kill
super + {shift + ,alt + }q
	[ "$(bspc query -T -n focused|jq .client.className -r)" = "tabbed" ]\
	&& (id="$(bsptab list|head -n1)"; bsptab remove $id && sleep 0.1 && bspc node $id -{c,k})\
	|| bspc node -{c,k}


# Increase/Decrease Gaps
super + {equal, minus} 
    { bspc config -d focused window_gap $(( $(bspc config -d focused window_gap) + 10 )), \
    [ $(bspc config -d focused window_gap) -ge 10 ] && \
			bspc config -d focused window_gap $(( $(bspc config -d focused window_gap) - 10 )) }



#######################################################################
#                            Window State                             #
#######################################################################

# Add or remove window from tabbed wrapper
super + {_,shift + }w
	bsptab {add,remove}

# Alternate between the tiled and monocle layout
super + a
	bspc desktop -l next;\
	polybar-msg action bspwm-monocle hook 0

# Toggle Floating/Tiled
super + s
	state="$(bspc query -T -n |jq ".client.state" -r)";\
	[ "$state" = "floating" ] && bspc node -t tiled || bspc node -t floating
	# bspc node -t "~floating"

# Toggle Pseudo Tiled/Tiled
super + t
	state="$(bspc query -T -n |jq ".client.state" -r)";\
	[ "$state" = "pseudo_tiled" ] && bspc node -t tiled || bspc node -t pseudo_tiled

# Toggle fullscreen
super + f 
  bspc node -t "~fullscreen"	

# Set Window as locked/sticky/private
super + ctrl + {o,s,p}
	bspc node -g {locked,sticky,private}

# Mark node or move marked node to preselection
super + ctrl + a
	if [ -n "$(bspc query -N -n .marked.\!floating.\!focused.window)" ];then;\
		bspc node newest.marked -n newest.\!automatic;\
		bspc query -N -n .\!floating|xargs -i bspc node \{\} -g marked=off;\
	else;\
		bspc node -g marked;\
	fi


