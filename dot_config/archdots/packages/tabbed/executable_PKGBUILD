pkgname=tabbed
pkgver=0.8

description='simple generic tabbed frontend to xembed-aware applications'
url='https://tools.suckless.org/tabbed'
depends=('pacman:libx11' 'pacman:libxft')
source=("https://dl.suckless.org/tools/${pkgname}-${pkgver}.tar.gz")

install() {
  cd "${pkgname}-${pkgver}"

  make
  mkdir -p ~/.local/bin
  mv tabbed ~/.local/bin
}

uninstall() {
  cd "$pkgname-$pkgver"

  make clean
  rm ~/.local/bin/tabbed
}

check() {
  which tabbed
}
