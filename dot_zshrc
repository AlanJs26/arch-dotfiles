### Yazi Config
function lf() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}
### End of Yazi Config

### Aliases
alias "docker compose"="docker-compose"

alias ls="eza"
alias ll="eza --long"
alias l="eza --long"

alias clear='printf '\''\033[2J\033[3J\033[1;1H'\'''

alias cat="bat"
alias gits="git status"
alias gitb="git branch -a"
alias lg="lazygit"
alias copy="xclip -sel copy"

alias lddtree="libtree"

alias run="run.sh"
alias open="run.sh"

function zz(){
    result="$(zoxide query $@|head -n1)"

    echo $result
    ls $result
}

function rm(){
    chezmoi destroy --force $@ 2> /dev/null || /bin/rm $@
}
