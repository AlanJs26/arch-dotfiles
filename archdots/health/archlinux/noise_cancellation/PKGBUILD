description='pipewire plugin that uses rnnoise to create a sink with noise cancellation'
url=''
depends=()
source=('https://github.com/werman/noise-suppression-for-voice/releases/latest/download/linux-rnnoise.zip')
# make this health script platform specific. Supported platforms: linux, windows
platform='archlinux'

# All items of source will be downloaded and extracted (when necessary)
# all downloaded (or extracted folders) are stored inside ${sourced[@]}
# This script is ran inside a folder over ~/.cache/archdots/pkgname, where all sources are downloaded
#
# $PKGPATH has the path to folder containing this file

# This function is used to configure the health script
install() {
  sudo mv ${sourced[0]} /usr/lib
  cp "$PKGPATH/99-input-denoising.conf" "$HOME/.config/pipewire/pipewire-pulse.conf.d"

  systemctl --user enable pipewire wireplumber pipewire-pulse
  systemctl --user restart pipewire wireplumber pipewire-pulse
}

# This function is used to unconfigure the health script
uninstall() {
  rnnoise_path="/usr/lib/$(basename "${sourced[0]}")"
  if [[ rnnoise_path -ef '/usr/lib' ]]; then
    echo "Error in source ${sourced[0]}"
    exit 1
  fi
  sudo rm -r "$rnnoise_path"
  rm "$HOME/.config/pipewire/pipewire-pulse.conf.d"
}

# This function should end with exit code 0 when the health script is configured
# and end with exit code 1 when it is unconfigured
check() {
  if [[ ! -d /usr/lib/linux-rnnoise ]]; then
    exit 1
  fi
}

