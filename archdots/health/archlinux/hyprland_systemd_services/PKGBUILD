description='install the systemd service located at hyprland config'
url=''
depends=('pacman:ripgrep' 'pacman:sttr-bin')
source=()
# source_on_check=false
# make this health script platform specific. Supported platforms: linux, windows
platform='archlinux'

# All items of source will be downloaded and extracted (when necessary)
# all downloaded (or extracted folders) are stored inside ${sourced[@]}
# This script is ran inside a folder over ~/.cache/archdots/pkgname, where all sources are downloaded
#
# $PKGPATH has the path to folder containing this file

# This function is used to configure the health script
install() {
  SOURCE_DIR="$HOME/.config/hypr/systemd"
  DEST_DIR="$HOME/.config/systemd/user"

  source_files="$(/usr/bin/ls -p $SOURCE_DIR | grep -v '/$' | sort)"

  mkdir -p "$DEST_DIR"

  cp $SOURCE_DIR/* $DEST_DIR

  systemctl --user daemon-reload

  # cat <<<$source_files | xargs -i systemctl --user enable --now {}
}

# This function is used to unconfigure the health script
uninstall() {
  SOURCE_DIR="$HOME/.config/hypr/systemd"
  DEST_DIR="$HOME/.config/systemd/user"

  source_files="$(/usr/bin/ls -p $SOURCE_DIR | grep -v '/$' | sort)"
  dest_files="$(/usr/bin/ls -p $DEST_DIR | grep -v '/$' | sort)"

  common_files="$(grep -Fxf <(cat <<<$dest_files) <(cat <<<$source_files))"

  n_common_files=$(sttr count-lines <<<$common_files)
  n_source_files=$(sttr count-lines <<<$source_files)

  cat <<<$common_files | xargs -i echo "rm $DEST_DIR/{}!"
}

# This function should end with exit code 0 when the health script is configured
# and end with exit code 1 when it is unconfigured
check() {
  SOURCE_DIR="$HOME/.config/hypr/systemd"
  DEST_DIR="$HOME/.config/systemd/user"

  source_files="$(/usr/bin/ls -p $SOURCE_DIR | grep -v '/$' | sort)"
  dest_files="$(/usr/bin/ls -p $DEST_DIR | grep -v '/$' | sort)"

  common_files="$(grep -Fxf <(cat <<<$dest_files) <(cat <<<$source_files))"

  n_common_files=$(sttr count-lines <<<$common_files)
  n_source_files=$(sttr count-lines <<<$source_files)

  if [[ $n_common_files -ne $n_source_files ]]; then
    exit 1
  fi

  source_content="$(cat <<<$common_files | xargs -i cat "$SOURCE_DIR/{}" | sort)"
  dest_content="$(cat <<<$common_files | xargs -i cat "$DEST_DIR/{}" | sort)"

  if [ "$source_content" != "$dest_content" ]; then
    exit 1
  fi

  exit 0
}
