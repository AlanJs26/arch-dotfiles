# :command.initialize
initialize() {
  version="0.1.0"
  long_usage=''
  set -e

}

# :command.run
run() {
  declare -A args=()
  declare -A deps=()
  declare -a other_args=()
  declare -a input=()
  normalize_input "$@"
  parse_requirements "${input[@]}"

  case "$action" in
    "setup") archdots_setup_command ;;
    "setup all") archdots_setup_all_command ;;
    "setup git-credentials") archdots_setup_git_credentials_command ;;
    "setup git-delta") archdots_setup_git_delta_command ;;
    "edit") archdots_edit_command ;;
    "diff") archdots_diff_command ;;
    "sync") archdots_sync_command ;;
    "sync all") archdots_sync_all_command ;;
    "sync apps") archdots_sync_apps_command ;;
    "sync dots") archdots_sync_dots_command ;;
    "cd") archdots_cd_command ;;
    "cd dots") archdots_cd_dots_command ;;
    "cd apps") archdots_cd_apps_command ;;
    "git") archdots_git_command ;;
    "list") archdots_list_command ;;
  esac
}

initialize
run "$@"
