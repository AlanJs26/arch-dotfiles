      archdots_edit_parse_requirements "$@"
      shift $#
      ;;

    diff)
      action="diff"
      shift
      archdots_diff_parse_requirements "$@"
      shift $#
      ;;

    settings)
      action="settings"
      shift
      archdots_settings_parse_requirements "$@"
      shift $#
      ;;

    alternate_config)
      action="alternate_config"
      shift
      archdots_alternate_config_parse_requirements "$@"
      shift $#
      ;;

    launch)
      action="launch"
      shift
      archdots_launch_parse_requirements "$@"
      shift $#
      ;;

    autostart)
      action="autostart"
      shift
      archdots_autostart_parse_requirements "$@"
      shift $#
      ;;

    sync)
      action="sync"
      shift
      archdots_sync_parse_requirements "$@"
      shift $#
      ;;

    cd)
      action="cd"
      shift
      archdots_cd_parse_requirements "$@"
      shift $#
      ;;

    review)
      action="review"
      shift
      archdots_review_parse_requirements "$@"
      shift $#
      ;;

    status)
      action="status"
      shift
      archdots_status_parse_requirements "$@"
      shift $#
      ;;

    git)
