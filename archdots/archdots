# :command.parse_requirements
parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        archdots_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    setup)
      action="setup"
      shift
      archdots_setup_parse_requirements "$@"
      shift $#
      ;;

    edit)
      action="edit"
      shift
      archdots_edit_parse_requirements "$@"
      shift $#
      ;;

    diff)
      action="diff"
      shift
      archdots_diff_parse_requirements "$@"
      shift $#
      ;;

    sync)
      action="sync"
      shift
      archdots_sync_parse_requirements "$@"
      shift $#
      ;;

    cd)
      action="cd"
      shift
      archdots_cd_parse_requirements "$@"
      shift $#
      ;;

    review)
      action="review"
      shift
      archdots_review_parse_requirements "$@"
      shift $#
      ;;

    status)
      action="status"
      shift
      archdots_status_parse_requirements "$@"
      shift $#
      ;;

    git)
      action="git"
      shift
      archdots_git_parse_requirements "$@"
      shift $#
      ;;

    list)
      action="list"
      shift
      archdots_list_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    "")
      archdots_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

# :command.parse_requirements
archdots_setup_parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --help | -h)
        long_usage=yes
        archdots_setup_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    all)
      action="all"
      shift
      archdots_setup_all_parse_requirements "$@"
