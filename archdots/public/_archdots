#compdef archdots

function _archdots {
    local line
    local commands=($(basename -s .sh -a ~/.local/share/chezmoi/archdots/src/commands/*|uniq))

    _arguments \
        "1:my message:(${commands})" \
        "*::arg:->args"
        # "2:my message:(boo foo)" \

    case $line[1] in
        edit)
            _archdots_edit
        ;;
    esac
}

function _archdots_edit {
    local pacdef_groups=($(pacdef group list))
    _arguments \
        "1:arg:(${pacdef_groups})"
}

