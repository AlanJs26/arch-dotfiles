		-rm -f ./$(DEPDIR)/evrouter-action_shell.Po
	-rm -f ./$(DEPDIR)/evrouter-action_xbutton.Po
	-rm -f ./$(DEPDIR)/evrouter-action_xkey.Po
	-rm -f ./$(DEPDIR)/evrouter-action_xmms.Po
	-rm -f ./$(DEPDIR)/evrouter-cmdline.Po
	-rm -f ./$(DEPDIR)/evrouter-evdev.Po
	-rm -f ./$(DEPDIR)/evrouter-evrouter.Po
	-rm -f ./$(DEPDIR)/evrouter-parser.Po
	-rm -f ./$(DEPDIR)/evrouter-x11.Po
	-rm -f Makefile
distclean-am: clean-am distclean-compile distclean-generic \
	distclean-tags

