evrouter_CFLAGS = $(CFLAGS) -Wall -g -D__USE_GNU $(XMMS_CFLAGS)
evrouter_SOURCES = \
		evrouter.c \
		cmdline.c cmdline.h \
		evdev.c evdev.h \
		parser.c parser.h \
		x11.c x11.h \
		action_shell.c action_shell.h \
		action_xkey.c action_xkey.h \
		action_xbutton.c action_xbutton.h \
		action_xmms.c action_xmms.h


