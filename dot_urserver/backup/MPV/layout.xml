<?xml version="1.0" encoding="utf-8"?>
<layout onResume="launch" onVolumeUp="volume_up" onVolumeDown="volume_down" color="34113A">
  <tabs>
    <tab text="playback">
      <row>
        <label id="title" weight="3" ontap="refreshtitle"/>
        <button icon="fullscreen" onTap="fullscreen" />
      </row>
      <row weight="4">
        <button icon="vdown" onTap="volume_down" />
        <grid>
          <row weight="2">
            <button icon="down" onTap="volume_down_mpv" />
            <button icon="up" onTap="volume_up_mpv" />
          </row>
          <button icon="next" onTap="skip_segment" />
        </grid>
        <button icon="vup" onTap="volume_up" />
      </row>
      <row>
        <slider id="pos" text="Position" progressmax="100" onup="seek" />
      </row>
      <row weight="2">
        <grid>
          <row> <button icon="left" onTap="leftBit" /> </row>
          <row> <button icon="rwd" onTap="left" /> </row>
        </grid>
        <button icon="playpause" onTap="play_pause" />
        <grid>
          <row> <button icon="right" onTap="rightBit" /> </row>
          <row> <button icon="ff" onTap="right" /> </row>
        </grid>
      </row>
    </tab>
    <tab text="risk">
      <row weight="1">
        <button icon="previous" onTap="prevEp" />
        <button icon="next" onTap="nextEp" />
        <button icon="off" onTap="hide" />
        <button icon="on" onTap="show" />
      </row> 
      <row weight="6">
        <list id="list" onhold="listitem">
          <item text="waiting refresh" />
        </list>
      </row>
      <row >
        <button icon="docclose" onHold="closempv" />
        <button weight="5" ontap="refreshlist" icon="refresh"/>
      </row>
    </tab>
    <tab text="window">
      <row weight="1">
        <button icon="shuffle" onTap="focusnextscreen" id="focusnextscreen" />
        <button icon="eject" onTap="sendtoavailableworkspace" id="sendtoavailableworkspace" />
        <button icon="arrowleft" onTap="focusprevworkspace" />
        <button icon="arrowright" onTap="focusnextworkspace" />
      </row> 
      <row >
        <button icon="off" onTap="windowmodetogglebutton" id="windowmodetogglebutton" />
        <button icon="up" onTap="focuswinup" />
        <button icon="window" onTap="show" onHold="hide" />
      </row>
      <row >
        <button icon="left" onTap="focuswinleft" />
        <button icon="unlock" onTap="windowtogglebutton" id="windowtogglebutton" />
        <button icon="right" onTap="focuswinright" />
      </row>
      <row >
        <button icon="windows" onTap="showrunmenu" onHold="esc" />
        <button icon="down" onTap="focuswindown" />
        <button icon="docclose" onHold="closewin" onTap="showpowermenu" />
      </row>
    </tab>
  </tabs>
</layout>
